        document.querySelectorAll(".js-service-cta").forEach((link) => {
          link.addEventListener("click", () => {
            const value = serviceMap[link.dataset.service];
            if (!value) return;

            const input = document.getElementById("serviceInput");
            const label = document.getElementById("serviceSelectText");
            const option = document.querySelector(
              `.aqua-select-option[data-value="${value}"]`,
            );

            if (input) input.value = value;

            if (label && option) {
              label.textContent = option.textContent.trim();

              const i18nKey = option.getAttribute("data-i18n");
              if (i18nKey) {
                label.setAttribute("data-i18n", i18nKey);
              }
            }

            document
              .querySelectorAll(".aqua-select-option")
              .forEach((item) => item.classList.remove("is-selected"));

            option?.classList.add("is-selected");
          });
        });

        const consent = localStorage.getItem("aqua_analytics_consent");
        const banner = document.getElementById("consent-banner");

        if (banner && consent === null) {
          setTimeout(() => banner.classList.add("is-visible"), 900);
        }

        document
          .getElementById("consentAccept")
          ?.addEventListener("click", () => {
            banner?.classList.remove("is-visible");
            window.__aquaEnableAnalytics?.();
          });

        document
          .getElementById("consentDecline")
          ?.addEventListener("click", () => {
            banner?.classList.remove("is-visible");
            window.__aquaDeclineAnalytics?.();
          });

        document
          .getElementById("successModalClose")
          ?.addEventListener("click", () => {
            document
              .getElementById("successModal")
              ?.classList.remove("is-open");
          });
      })();
    </script>

