    <!-- AquaTech reveal animations script -->
    <script>
      (() => {
        const selectors = [
          "section",
          ".glass-card",
          ".service-card",
          ".result-card",
          ".solution-card",
          ".faq-item",
          ".contact-card",
        ];

        const items = Array.from(
          document.querySelectorAll(selectors.join(",")),
        ).filter(
          (el) =>
            !el.closest("header") && !el.classList.contains("aqua-reveal"),
        );

        items.forEach((el, index) => {
          el.classList.add("aqua-reveal");
          el.style.setProperty(
            "--aqua-delay",
            Math.min(index % 6, 5) * 70 + "ms",
          );
        });

        const hoverTargets = document.querySelectorAll(
          ".glass-card a, .service-card a, a[href^='https://wa.me'], a[href^='mailto:'], a[aria-label='Instagram'], a[aria-label='GitHub'], a[aria-label='LinkedIn'], a[aria-label='Facebook']",
        );

        hoverTargets.forEach((el) => {
          el.classList.add("aqua-hover-lift");
        });

        if (!("IntersectionObserver" in window)) {
          items.forEach((el) => el.classList.add("is-visible"));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          {
            threshold: 0.12,
            rootMargin: "0px 0px -60px 0px",
          },
        );

        items.forEach((el) => observer.observe(el));
      })();
    </script>

