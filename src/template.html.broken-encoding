    <style>
      :root {
        --aqua-bg: #051424;
        --aqua-deep: #010f1f;
        --aqua-card: rgba(15, 23, 42, 0.6);
        --aqua-card-solid: #122131;
        --aqua-line: rgba(137, 206, 255, 0.12);
        --aqua-line-strong: rgba(137, 206, 255, 0.34);
        --aqua-primary: #89ceff;
        --aqua-action: #00b4ff;
        --aqua-text: #d4e4fa;
        --aqua-muted: #bdc8d2;
      }

      html {
        scroll-behavior: smooth;
      }
      body {
        background:
          radial-gradient(
            circle at 50% 0%,
            rgba(0, 180, 255, 0.16),
            transparent 34%
          ),
          radial-gradient(
            circle at 12% 18%,
            rgba(137, 206, 255, 0.08),
            transparent 28%
          ),
          linear-gradient(180deg, #051424 0%, #03101f 52%, #010915 100%);
        color: var(--aqua-text);
        font-family:
          Inter,
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
        overflow-x: hidden;
      }

      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
        line-height: 1;
      }

      .glass-card {
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(137, 206, 255, 0.1);
        box-shadow:
          0 0 0 1px rgba(255, 255, 255, 0.015) inset,
          0 22px 80px rgba(0, 0, 0, 0.24);
        transition:
          border-color 0.3s ease,
          box-shadow 0.3s ease,
          transform 0.3s ease,
          background 0.3s ease;
      }

      .glass-card:hover {
        border-color: rgba(137, 206, 255, 0.34);
        box-shadow:
          0 0 0 1px rgba(255, 255, 255, 0.02) inset,
          0 22px 80px rgba(0, 0, 0, 0.28),
          0 0 24px rgba(0, 180, 255, 0.13);
      }

      .glow-text {
        text-shadow: 0 0 10px rgba(137, 206, 255, 0.5);
      }

      .terminal-cursor::after {
        content: "_";
        animation: blink 1s step-end infinite;
      }
      @keyframes blink {
        50% {
          opacity: 0;
        }
      }

      .service-cta-btn {
        width: fit-content;
        min-height: 2.55rem;
        margin-top: auto;
        padding: 0.65rem 1rem;
        border-radius: 0.9rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.55rem;
        color: var(--aqua-primary);
        background:
          linear-gradient(
            135deg,
            rgba(137, 206, 255, 0.1),
            rgba(0, 180, 255, 0.045)
          ),
          rgba(137, 206, 255, 0.045);
        border: 1px solid rgba(137, 206, 255, 0.26);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.05),
          0 10px 26px rgba(0, 0, 0, 0.14);
        font-weight: 800;
        font-size: 0.85rem;
        text-decoration: none;
        transition:
          transform 0.2s ease,
          background 0.2s ease,
          border-color 0.2s ease,
          box-shadow 0.2s ease,
          color 0.2s ease;
      }

      .service-cta-btn:hover {
        color: #001e2f;
        background: linear-gradient(135deg, #89ceff, #00b4ff);
        border-color: rgba(255, 255, 255, 0.28);
        transform: translateY(-2px);
        box-shadow:
          0 14px 34px rgba(0, 180, 255, 0.22),
          0 0 18px rgba(137, 206, 255, 0.12);
      }

      .service-cta-btn-primary {
        color: #001e2f;
        background: linear-gradient(135deg, #89ceff, #00b4ff);
        border-color: rgba(255, 255, 255, 0.28);
      }

      .service-cta-btn .btn-icon {
        font-size: 1.1rem;
        line-height: 1;
        transition: transform 0.2s ease;
      }

      .service-cta-btn:hover .btn-icon {
        transform: translateX(-4px);
      }

      @media (max-width: 767px) {
        .service-cta-btn {
          width: 100%;
        }
      }

      .aqua-liquid-bg {
        position: absolute;
        inset: 0;
        z-index: -1;
        overflow: hidden;
        pointer-events: none;
      }
      .aqua-liquid-bg::before,
      .aqua-liquid-bg::after {
        content: "";
        position: absolute;
        border-radius: 999px;
        filter: blur(46px);
        opacity: 0.35;
        animation: drift 12s ease-in-out infinite;
      }
      .aqua-liquid-bg::before {
        width: 520px;
        height: 520px;
        top: 10%;
        right: 8%;
        background: radial-gradient(
          circle,
          rgba(0, 180, 255, 0.34),
          transparent 64%
        );
      }
      .aqua-liquid-bg::after {
        width: 460px;
        height: 460px;
        bottom: 16%;
        left: 8%;
        background: radial-gradient(
          circle,
          rgba(137, 206, 255, 0.2),
          transparent 68%
        );
        animation-delay: -5s;
      }
      @keyframes drift {
        0%,
        100% {
          transform: translate3d(0, 0, 0) scale(1);
        }
        50% {
          transform: translate3d(18px, -14px, 0) scale(1.04);
        }
      }

      .circuit-layer {
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: 0.28;
        background-image:
          linear-gradient(
            to right,
            rgba(137, 206, 255, 0.06) 1px,
            transparent 1px
          ),
          linear-gradient(
            to bottom,
            rgba(137, 206, 255, 0.045) 1px,
            transparent 1px
          ),
          radial-gradient(
            circle at 20% 30%,
            rgba(137, 206, 255, 0.18) 0 2px,
            transparent 3px
          ),
          radial-gradient(
            circle at 78% 26%,
            rgba(0, 180, 255, 0.18) 0 2px,
            transparent 3px
          ),
          radial-gradient(
            circle at 52% 78%,
            rgba(137, 206, 255, 0.12) 0 2px,
            transparent 3px
          );
        background-size:
          92px 92px,
          92px 92px,
          520px 520px,
          620px 620px,
          700px 700px;
        mask-image: radial-gradient(
          circle at 50% 20%,
          rgba(0, 0, 0, 0.9),
          transparent 74%
        );
        -webkit-mask-image: radial-gradient(
          circle at 50% 20%,
          rgba(0, 0, 0, 0.9),
          transparent 74%
        );
      }

      .code-chip {
        position: absolute;
        font-family: "JetBrains Mono", monospace;
        color: rgba(212, 228, 250, 0.2);
        letter-spacing: 0.1em;
        user-select: none;
        text-shadow: 0 0 18px rgba(137, 206, 255, 0.12);
      }

      .section-kicker {
        display: block;
        margin-bottom: 1rem;
        color: var(--aqua-primary);
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.2em;
        text-transform: none;
      }

      .aqua-card-kicker {
        display: inline-flex;
        width: fit-content;
        margin-bottom: 1rem;
        color: var(--aqua-primary);
        font-family: "Alexandria", system-ui, sans-serif;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0;
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        border: 1px solid rgba(137, 206, 255, 0.18);
        background: rgba(137, 206, 255, 0.055);
      }

      .aqua-input {
        width: 100%;
        border-radius: 0.75rem;
        border: 1px solid rgba(137, 206, 255, 0.14);
        background: rgba(1, 15, 31, 0.62);
        color: var(--aqua-text);
        padding: 0.9rem 1rem;
        outline: none;
        transition:
          border-color 0.2s ease,
          box-shadow 0.2s ease,
          background 0.2s ease;
      }
      .aqua-input::placeholder {
        color: rgba(189, 200, 210, 0.55);
      }
      .aqua-input:focus {
        border-color: rgba(137, 206, 255, 0.65);
        box-shadow:
          inset 0 0 10px rgba(137, 206, 255, 0.14),
          0 0 0 4px rgba(137, 206, 255, 0.06);
        background: rgba(1, 15, 31, 0.86);
      }
      select.aqua-input option {
        background: #0d1c2d;
        color: #d4e4fa;
      }
      .aqua-btn .btn-icon {
        font-size: 1.15rem;
        line-height: 1;
        transition: transform 0.2s ease;
      }

      .aqua-btn:hover .btn-icon {
        transform: translateX(-4px);
      }

      .offer-cta-btn {
        width: 100%;
        min-height: 3.15rem;
        margin-top: auto;
        padding: 0.85rem 1rem;
        border-radius: 0.95rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.55rem;
        color: #d4e4fa;
        background:
          linear-gradient(
            135deg,
            rgba(137, 206, 255, 0.12),
            rgba(0, 180, 255, 0.06)
          ),
          rgba(137, 206, 255, 0.055);
        border: 1px solid rgba(137, 206, 255, 0.32);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.06),
          0 10px 28px rgba(0, 0, 0, 0.18);
        font-weight: 800;
        text-decoration: none;
      }

      .offer-cta-btn:hover {
        color: #001e2f;
        background: linear-gradient(135deg, #89ceff, #00b4ff);
        border-color: rgba(255, 255, 255, 0.28);
        transform: translateY(-2px);
        box-shadow:
          0 16px 38px rgba(0, 180, 255, 0.24),
          0 0 18px rgba(137, 206, 255, 0.16);
      }

      .offer-cta-btn .btn-icon {
        font-size: 1.1rem;
        transition: transform 0.2s ease;
      }

      .offer-cta-btn:hover .btn-icon {
        transform: translateX(-4px);
      }

      .offer-cta-btn-primary {
        color: #001e2f;
        background: linear-gradient(135deg, #89ceff, #00b4ff);
        border-color: rgba(255, 255, 255, 0.28);
      }


      .offer-discovery-card > div:first-child {
        flex: 1 1 auto;
        min-width: 0;
      }

      @media (min-width: 1024px) {
        .offer-discovery-card .offer-cta-btn {
          width: 320px;
          max-width: 320px;
        }
      }

      .nav-link {
        position: relative;
      }
      .nav-link::after {
        content: "";
        position: absolute;
        right: 0;
        left: 0;
        bottom: -8px;
        height: 2px;
        background: var(--aqua-primary);
        transform: scaleX(0);
        transform-origin: center;
        transition: transform 0.2s ease;
        opacity: 0.9;
      }
      .nav-link:hover::after,
      .nav-link.is-active::after {
        transform: scaleX(1);
      }

      #mobileMenu {
        position: fixed;
        top: 6.75rem;
        left: 0.75rem;
        right: 0.75rem;
        z-index: 60;

        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transform: translateY(-10px);

        transition:
          opacity 180ms ease,
          transform 180ms ease,
          visibility 180ms ease;
      }

      #mobileMenu.is-open {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transform: translateY(0);
      }

      #wa-float {
        position: fixed;
        left: 20px;
        bottom: 22px;
        z-index: 80;
        width: 56px;
        height: 56px;
        border-radius: 999px;
        display: grid;
        place-items: center;
        color: #001e2f;
        background: linear-gradient(135deg, #89ceff, #00b4ff);
        box-shadow:
          0 16px 42px rgba(0, 0, 0, 0.34),
          0 0 20px rgba(0, 180, 255, 0.22);
        border: 1px solid rgba(255, 255, 255, 0.2);
        transition:
          transform 0.2s ease,
          filter 0.2s ease;
      }
      #wa-float:hover {
        transform: translateY(-2px) scale(1.05);
        filter: saturate(1.1);
      }

      #consent-banner {
        position: fixed;
        left: 16px;
        right: 16px;
        bottom: 16px;
        z-index: 100;
        display: none;
        gap: 1rem;
        align-items: center;
        justify-content: space-between;
        padding: 1rem;
        border-radius: 1rem;
        background: rgba(1, 15, 31, 0.96);
        border: 1px solid rgba(137, 206, 255, 0.18);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
      }
      #consent-banner.is-visible {
        display: flex;
      }

      .success-modal {
        position: fixed;
        inset: 0;
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 120;
        padding: 1rem;
        background: rgba(1, 15, 31, 0.72);
        backdrop-filter: blur(10px);
      }
      .success-modal.is-open {
        display: flex;
      }
      .success-modal-card {
        width: min(100%, 28rem);
        text-align: center;
        padding: 2rem;
        border-radius: 1.25rem;
        background: #122131;
        border: 1px solid rgba(137, 206, 255, 0.18);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
      }
      .success-modal-icon {
        width: 64px;
        height: 64px;
        display: grid;
        place-items: center;
        margin: 0 auto 1rem;
        border-radius: 999px;
        background: rgba(137, 206, 255, 0.12);
        border: 1px solid rgba(137, 206, 255, 0.28);
        color: #89ceff;
        font-size: 28px;
        font-weight: 800;
      }

      @media (max-width: 767px) {
        .aqua-liquid-bg::before,
        .aqua-liquid-bg::after {
          opacity: 0.18;
          filter: blur(34px);
        }
        .circuit-layer {
          opacity: 0.12;
        }
        .code-chip {
          display: none;
        }
        #consent-banner {
          flex-direction: column;
          align-items: stretch;
          text-align: center;
        }
        #wa-float {
          width: 50px;
          height: 50px;
          left: 14px;
          bottom: 14px;
        }
      }

      .wa-svg {
        width: 1.25rem;
        height: 1.25rem;
        display: block;
      }

      #wa-float .wa-svg {
        width: 1.75rem;
        height: 1.75rem;
      }

      #langToggle {
        direction: ltr;
      }
      .aqua-custom-select {
        position: relative;
        width: 100%;
      }

      .social-icons-grid {
        display: grid;
        grid-template-columns: repeat(3, 58px);
        justify-content: center;
        column-gap: 26px;
        row-gap: 20px;
        width: 100%;
      }

      .social-icon-link {
        width: 58px;
        height: 58px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 16px;
        border: 1px solid rgba(137, 206, 255, 0.28);
        background: rgba(137, 206, 255, 0.06);
        color: var(--aqua-primary);
        text-decoration: none;
        transition:
          background 0.2s ease,
          border-color 0.2s ease,
          color 0.2s ease,
          transform 0.2s ease;
      }

      .social-icon-link:hover {
        background: var(--aqua-primary);
        color: #001e2f;
        border-color: rgba(255, 255, 255, 0.28);
        transform: translateY(-2px);
      }

      .social-icon-link .material-symbols-outlined {
        font-size: 25px;
      }

      .social-icon-link svg {
        width: 25px;
        height: 25px;
        display: block;
      }

      @media (max-width: 420px) {
        .social-icons-grid {
          grid-template-columns: repeat(3, 52px);
          row-gap: 14px;
        }

        .social-icon-link {
          width: 52px;
          height: 52px;
          border-radius: 14px;
        }
      }

      .aqua-select-trigger {
        width: 100%;
        min-height: 3.55rem;
        padding: 0.9rem 1rem;
        border-radius: 0.75rem;
        border: 1px solid rgba(137, 206, 255, 0.14);
        background: rgba(1, 15, 31, 0.62);
        color: var(--aqua-text);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        outline: none;
        text-align: inherit;
      }

      .aqua-select-trigger:focus,
      .aqua-custom-select.is-open .aqua-select-trigger {
        border-color: rgba(137, 206, 255, 0.65);
        box-shadow:
          inset 0 0 10px rgba(137, 206, 255, 0.14),
          0 0 0 4px rgba(137, 206, 255, 0.06);
        background: rgba(1, 15, 31, 0.9);
      }

      .aqua-select-menu {
        position: absolute;
        top: calc(100% + 0.55rem);
        left: 0;
        right: 0;
        z-index: 200;
        display: none;
        max-height: 18rem;
        overflow-y: auto;
        padding: 0.6rem;
        border-radius: 1rem;
        border: 1px solid rgba(137, 206, 255, 0.24);
        background: #071827;
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.5);

        scrollbar-width: none;
        -ms-overflow-style: none;
      }

      .aqua-select-menu::-webkit-scrollbar {
        width: 0;
        height: 0;
        display: none;
      }

      .aqua-custom-select.is-open .aqua-select-menu {
        display: block;
      }

      .aqua-select-group {
        padding: 0.55rem 0.75rem 0.35rem;
        color: var(--aqua-primary);
        font-family: "JetBrains Mono", monospace;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: none;
        opacity: 0.95;
      }

      .aqua-select-option {
        width: 100%;
        display: block;
        border: 0;
        background: transparent;
        color: var(--aqua-text);
        text-align: right;
        padding: 0.7rem 0.75rem;
        border-radius: 0.75rem;
        cursor: pointer;
        font: inherit;
        line-height: 1.35;
      }

      html[dir="ltr"] .aqua-select-option {
        text-align: left;
      }

      .aqua-select-option:hover,
      .aqua-select-option.is-selected {
        background: rgba(137, 206, 255, 0.12);
        color: #ffffff;
      }

      .aqua-select-error {
        display: none;
        margin-top: 0.5rem;
        color: #fca5a5;
        font-size: 0.8rem;
      }

      .aqua-select-error.is-visible {
        display: block;
      }

      /* Aqua.Tech icon system - no images */
      .aqua-icon-box {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        color: var(--aqua-primary);
        background:
          radial-gradient(
            circle at 35% 20%,
            rgba(137, 206, 255, 0.18),
            transparent 56%
          ),
          linear-gradient(
            135deg,
            rgba(137, 206, 255, 0.12),
            rgba(0, 180, 255, 0.045)
          ),
          rgba(15, 35, 55, 0.72);
        border: 1px solid rgba(137, 206, 255, 0.24);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.06),
          0 14px 35px rgba(0, 0, 0, 0.22),
          0 0 18px rgba(0, 180, 255, 0.06);
        transition:
          transform 0.22s ease,
          border-color 0.22s ease,
          background 0.22s ease,
          box-shadow 0.22s ease,
          color 0.22s ease;
      }

      .aqua-icon-box .material-symbols-outlined {
        font-size: 26px;
        color: currentColor;
      }

      .aqua-icon-box svg {
        width: 26px;
        height: 26px;
        display: block;
